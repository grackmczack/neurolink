# Google Drive OAuth Credentials (Phase 4)
# Du musst diese Werte aus der Google Cloud Console holen:
# https://console.cloud.google.com/apis/credentials
# Siehe README.md für Schritt-für-Schritt-Anleitung.

VITE_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your_client_secret_here
VITE_GOOGLE_REDIRECT_URI=http://localhost:1420/auth/callback
